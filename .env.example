# ============================================================
# Database Configuration (choose one)
# ============================================================

# Option 1: Supabase (managed PostgreSQL + pgvector)
DATABASE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Option 2: Direct PostgreSQL (Neon, Railway, self-hosted, etc.)
# DATABASE_PROVIDER=postgres
# POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# Option 3: SQLite (local/offline)
# DATABASE_PROVIDER=sqlite
# SQLITE_DB_PATH=~/.vault/vault.db

# ============================================================
# AWS Configuration (for Bedrock)
# ============================================================
AWS_REGION=us-east-1
AWS_PROFILE=default

# ============================================================
# OpenAI Configuration (optional, for future use)
# ============================================================
# OPENAI_API_KEY=sk-...

# ============================================================
# Embedding Configuration
# ============================================================
EMBEDDING_PROVIDER=bedrock-titan  # bedrock-titan | openai-small | openai-large
EMBEDDING_DIMENSION=1536

# ============================================================
# Application Settings
# ============================================================
LOG_LEVEL=INFO